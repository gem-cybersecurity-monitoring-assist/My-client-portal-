// Prisma schema — GEM & ATR Platform
// Database: PostgreSQL
// Run: pnpm db:push && npx prisma generate && pnpm db:seed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Core Models ───────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  hashedPassword String
  name           String
  role           String   // superadmin | admin | team | client
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  requests          ServiceRequest[] @relation("RequestClient")
  managedRequests   ServiceRequest[] @relation("RequestAdmin")
  approvals         Approval[]
  reportedIncidents Incident[]       @relation("IncidentReporter")
  assignedIncidents Incident[]       @relation("IncidentAssignee")
  auditLogs         AuditLog[]
  ownedPortfolios   Portfolio[]      @relation("PortfolioOwner")
  managedPortfolios Portfolio[]      @relation("PortfolioManager")
}

model ServiceRequest {
  id        String   @id @default(cuid())
  type      String   // Withdrawal | Deposit | Support | Account Change
  subject   String
  status    String   @default("Pending") // Pending | Approved | Rejected | In Review
  priority  String   @default("Medium")  // Low | Medium | High
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientId String
  client   User   @relation("RequestClient", fields: [clientId], references: [id])

  adminId String?
  admin   User?   @relation("RequestAdmin", fields: [adminId], references: [id])

  approvals Approval[]
}

model Approval {
  id        String   @id @default(cuid())
  action    String   // Approved | Rejected | In Review
  notes     String?
  createdAt DateTime @default(now())

  requestId String
  request   ServiceRequest @relation(fields: [requestId], references: [id])

  adminId String
  admin   User   @relation(fields: [adminId], references: [id])
}

model Incident {
  id          String   @id @default(cuid())
  title       String
  description String?
  severity    String   @default("Medium") // Low | Medium | High | Critical
  status      String   @default("Open")   // Open | In Progress | Resolved | Closed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reportedById String
  reportedBy   User   @relation("IncidentReporter", fields: [reportedById], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("IncidentAssignee", fields: [assignedToId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String?
  entityId  String?
  metadata  String?  // JSON string
  createdAt DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])
}

// ─── Portfolio Models ──────────────────────────────────────────────────────

model Portfolio {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("Active") // Active | Inactive | Closed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId String
  owner   User   @relation("PortfolioOwner", fields: [ownerId], references: [id])

  managedById String?
  managedBy   User?   @relation("PortfolioManager", fields: [managedById], references: [id])

  accounts     PortfolioAccount[]
  holdings     Holding[]
  transactions PortfolioTransaction[]
  snapshots    PerformanceSnapshot[]
}

model PortfolioAccount {
  id        String   @id @default(cuid())
  name      String
  type      String   // Cash | Investment | Retirement | Custodial
  balance   Float    @default(0)
  currency  String   @default("USD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

model Holding {
  id           String   @id @default(cuid())
  name         String
  symbol       String
  assetClass   String   // STOCK | CRYPTO | REAL_ESTATE | PRIVATE_EQUITY | BONDS | CASH
  quantity     Float
  costBasis    Float    // total cost basis in USD
  currentValue Float    // current market value in USD
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

model PortfolioTransaction {
  id           String   @id @default(cuid())
  type         String   // BUY | SELL | DIVIDEND | DEPOSIT | WITHDRAWAL | FEE | TRANSFER
  description  String
  amount       Float    // total USD amount (always positive; type indicates direction)
  quantity     Float?   // units (optional for cash txns)
  pricePerUnit Float?   // price per unit at execution (optional)
  symbol       String?  // ticker / asset symbol (optional)

  // Phase-7 additions
  status       String   @default("Confirmed") // Pending | Confirmed | Reversed
  adminNote    String?                         // admin correction/reversal note
  reversalOfId String?                         // ID of the original tx this reverses

  createdAt    DateTime @default(now())

  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

model PerformanceSnapshot {
  id           String   @id @default(cuid())
  date         DateTime
  totalValue   Float
  dayChange    Float    @default(0)
  dayChangePct Float    @default(0)
  createdAt    DateTime @default(now())

  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}
